# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ─── Dependencies ─────────────────────────────────────────────────────────────
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ─── Next.js ──────────────────────────────────────────────────────────────────
/.next/
/out/
/build

# ─── Testing ──────────────────────────────────────────────────────────────────
/coverage

# ─── Environment variables ────────────────────────────────────────────────────
# All .env files are ignored by default — never commit secrets.
.env
.env.local
.env.*.local
.env.development
.env.production
.env.test
# Allow example/template files so others can bootstrap the project
!.env.example
!.env.local.example
!.env.*.example

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Local Supabase CLI temp files (created by `supabase start`)
.supabase/

# ─── TypeScript ───────────────────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ─── Certificates & keys ──────────────────────────────────────────────────────
*.pem
*.key
*.p12
*.pfx

# ─── Debug logs ───────────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# ─── OS & editor ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/settings.json
.idea/

# ─── Deployment ───────────────────────────────────────────────────────────────
.vercel
